{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "Notification Service — RabbitMQ consumer, Twilio SMS, SendGrid email",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "amqplib": "^0.10.4",
    "dotenv": "^16.4.5",
    "twilio": "^5.1.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
