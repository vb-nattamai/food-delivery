# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fooddelivery
POSTGRES_USER=fooddelivery
POSTGRES_PASSWORD=changeme

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB=driverservice

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-256-bit-random-secret
JWT_EXPIRY_SECONDS=3600

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=replace_me

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+15550000000

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.replace_me
SENDGRID_FROM_EMAIL=noreply@fooddelivery.example.com
SENDGRID_FROM_NAME=Food Delivery
